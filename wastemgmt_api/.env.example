# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3023
HOST=0.0.0.0
LOG_LEVEL=info

# Public origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://wastemgmt.coraltele.com

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://rahulsinghcse79:Rahul%40r1.14l@freemongodb.guz6ovf.mongodb.net/wastemgmt?retryWrites=true&w=majority&appName=FreeMongodb

# ─── JWT / Crypto ────────────────────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION (use: openssl rand -hex 64)
JWT_ACCESS_SECRET=replace_with_64_byte_hex_string_for_access_token_signing_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_string_for_refresh_token_signing_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# AES-256-GCM key for encrypting sensitive request payloads (32 bytes hex = 64 chars)
PAYLOAD_ENC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Default seed accounts ───────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin
SEED_USER_USERNAME=user
SEED_USER_PASSWORD=user

# ─── MQTT (TLS) ──────────────────────────────────────────────────────────────
MQTT_ENABLED=true
MQTT_HOST=ccsp.m2m.minfoway.com
MQTT_PORT=8883
MQTT_PROTOCOL=mqtts
MQTT_CLIENT_ID=SOTcorws-01
MQTT_TOPIC=/oneM2M/resp/#
MQTT_CA_CERT=/etc/iotmqttcerts/ca.crt
MQTT_CLIENT_CERT=/etc/iotmqttcerts/SOTcorws-01.crt
MQTT_CLIENT_KEY=/etc/iotmqttcerts/SOTcorws-01.key
MQTT_REJECT_UNAUTHORIZED=true

# ─── SMTP (alerts) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@example.com
ALERT_EMAIL_TO=ops@example.com

# ─── Surveillance ────────────────────────────────────────────────────────────
CAMERA_STREAM_1=https://surveillance.coraltele.com/cam1
CAMERA_STREAM_2=https://surveillance.coraltele.com/cam2

# ─── Redis (optional, used for cache & rate-limit store) ─────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ─── Rate limit ──────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW=1 minute
